{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@crm/shared": ["packages/shared/src/index.ts"],
      "@crm/shared/*": ["packages/shared/src/*"],
      "@crm/ui": ["packages/ui/src/index.tsx"],
      "@crm/ui/*": ["packages/ui/src/*"]
    }
  }
}
