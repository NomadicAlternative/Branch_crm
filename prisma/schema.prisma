generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  pendiente
  asignada
  completada
}

enum AgreementStatus {
  pendiente
  en_progreso
  completado
}

model Organization {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  level       Int
  parentId    String?
  parent      Organization?  @relation("OrganizationHierarchy", fields: [parentId], references: [id])
  children    Organization[] @relation("OrganizationHierarchy")
  members     Member[]
  tasks       Task[]
  councilMinutes CouncilMinute[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  displayName String
  passwordHash String?
  role        String
  level       Int
  member      Member?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Member {
  id             String       @id @default(cuid())
  userId         String       @unique
  organizationId String
  phone          String?
  active         Boolean      @default(true)
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  assignedTasks  Task[]       @relation("AssignedTasks")
  createdTasks   Task[]       @relation("CreatedTasks")
  createdCouncilMinutes CouncilMinute[] @relation("CreatedCouncilMinutes")
  responsibleAgreements CouncilAgreement[] @relation("ResponsibleCouncilAgreements")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Task {
  id               String       @id @default(cuid())
  title            String
  description      String?
  status           TaskStatus   @default(pendiente)
  organizationId   String
  createdByMemberId String
  assignedToMemberId String?
  completedAt      DateTime?
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdBy        Member       @relation("CreatedTasks", fields: [createdByMemberId], references: [id])
  assignedTo       Member?      @relation("AssignedTasks", fields: [assignedToMemberId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
  @@index([assignedToMemberId])
}

model CouncilMinute {
  id                String             @id @default(cuid())
  title             String
  summary           String?
  meetingDate       DateTime
  organizationId    String
  createdByMemberId String
  organization      Organization       @relation(fields: [organizationId], references: [id])
  createdBy         Member             @relation("CreatedCouncilMinutes", fields: [createdByMemberId], references: [id])
  agreements        CouncilAgreement[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([organizationId])
}

model CouncilAgreement {
  id                  String          @id @default(cuid())
  minuteId            String
  title               String
  description         String?
  responsibleMemberId String
  status              AgreementStatus @default(pendiente)
  followUpComment     String?
  dueDate             DateTime?
  completedAt         DateTime?
  minute              CouncilMinute   @relation(fields: [minuteId], references: [id])
  responsibleMember   Member          @relation("ResponsibleCouncilAgreements", fields: [responsibleMemberId], references: [id])
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([minuteId])
  @@index([responsibleMemberId])
  @@index([status])
}
