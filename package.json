{
  "name": "crm-rama",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @crm/api prisma:generate",
    "db:migrate": "pnpm --filter @crm/api prisma:migrate",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "db:seed": "node --env-file=.env prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.6.0",
    "turbo": "^2.0.0",
    "typescript": "^5.8.0"
  }
}
